  <previewCommands>setup repeat 75 [ go ]</previewCommands>
  <experiments>
    <experiment name="Experiment 1 - Main" repetitions="1" sequentialRunOrder="true" runMetricsEveryStep="false" timeLimit="500">
      <setup>setup</setup>
      <go>go</go>
      <metrics>
        <metric>ticks</metric>
        <metric>wealthy-clinic-ratio</metric>
        <metric>dynamic-lifespace?</metric>
        <metric>count patients-on patches with [status = "poor"]</metric>
        <metric>count patients-on patches with [status = "wealthy"]</metric>
        <metric>count patches with [status = "poor"]</metric>
        <metric>count patches with [status = "wealthy"]</metric>
        <metric>total-poor-no-access</metric>
        <metric>total-wealthy-no-access</metric>
        <metric>total-poor-fail</metric>
        <metric>total-wealthy-fail</metric>
        <metric>total-poor-deaths</metric>
        <metric>total-wealthy-deaths</metric>
      </metrics>
      <constants>
        <steppedValueSet variable="seed-id" first="1" step="1" last="100"></steppedValueSet>
        <enumeratedValueSet variable="wealthy-clinic-ratio">
          <value value="0.5"></value>
          <value value="0.6"></value>
          <value value="0.7"></value>
          <value value="0.8"></value>
          <value value="0.9"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="scenario">
          <value value="&quot;1. Baseline (static life-space)&quot;"></value>
          <value value="&quot;2. Spiral of decline (dynamic life-space)&quot;"></value>
        </enumeratedValueSet>
      </constants>
    </experiment>
