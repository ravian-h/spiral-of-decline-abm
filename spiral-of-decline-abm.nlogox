<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 7.0.3" snapToGrid="false">
  <code><![CDATA[globals [ 
  ; per-tick counters
  poor-fail wealthy-fail
  poor-no-access wealthy-no-access
  wealthy-deaths poor-deaths

  ; cumulative counters
  total-poor-fail total-wealthy-fail
  total-poor-no-access total-wealthy-no-access
  total-wealthy-deaths total-poor-deaths

  ; model parameters
  total-patients total-clinics global-capacity
  care-threshold
  max-health-bonus max-wealth-bonus health-tipping-point

  ; mobile clinic parameters
  mobile-capacity mobile-amount relocation-threshold

  ; condition parameters
  dynamic-lifespace? mobile-clinic-intervention?

  ; experiment control
  seed-id
]

; agent types
breed [clinics clinic ]
clinics-own [remaining-capacity waiting-list ]

breed [mobile-clinics mobile-clinic]
mobile-clinics-own [remaining-capacity waiting-list time-at-location]

breed [patients patient]
patients-own [wealth health life-space ]


patches-own[ status ] ; poor or wealthy

to setup
  let saved-seed seed-id ; store seed before clear-all wipes the globals
  clear-all
  apply-scenario
  random-seed saved-seed
  no-display ; helps with rendering during setup
  create-zones
  place-clinics
  creating-patients
  
  if mobile-clinic-intervention? [
    place-mobile-clinics 
  ]
  
  reset-ticks
  display
end


to go
  reset-per-tick

  if mobile-clinic-intervention? [
    update-mobile-clinics
  ]

  ask patients [ update-health ]
  ask patients with [ health < care-threshold] [ choose-clinic ]
  ask clinics [ clinic-order ]

  if mobile-clinic-intervention? = true [
    ask mobile-clinics [ clinic-order ]
  ]
  
  tick
end

to reset-per-tick
  if show-links? [
    ask links [ die ] 
  ]
  
  ask clinics [
    set remaining-capacity global-capacity
    set waiting-list no-turtles
  ]
  ask mobile-clinics [
    set remaining-capacity mobile-capacity
    set waiting-list no-turtles
  ]
  set wealthy-fail 0
  set poor-fail 0
  set poor-no-access 0
  set wealthy-no-access 0
  set poor-deaths 0
  set wealthy-deaths 0
end

; Divides the environment into a poor and wealthy zone
; 8 seeds total: 3 wealthy, 5 poor
to create-zones
  let seeds n-of 8 patches
  
  let wealthy-seeds n-of 3 seeds
  let poor-seeds seeds with [ not member? self wealthy-seeds ]
  
  ask wealthy-seeds [ set status "wealthy" ] 
  ask poor-seeds [ set status "poor" ]
  
  ask patches [
    let nearest min-one-of seeds [ distance myself ] 
    set status [status] of nearest
    
    ifelse status = "wealthy"
    [ set pcolor green ]
    [ set pcolor grey ]
  ]
end

; distributes clinics across zones according to wealthy-clinic-ratio
to place-clinics
  let wealthy-count round (total-clinics * wealthy-clinic-ratio)
  let poor-count total-clinics - wealthy-count

  place-clinics-in-zone "wealthy" wealthy-count
  place-clinics-in-zone "poor" poor-count
end


to place-clinics-in-zone [ zone n ]
  repeat n [
    let candidates patches with [
      status = zone and
      not any? clinics-here and
      not any? clinics in-radius 10 ; minimum spacing between clinics
    ]

    if not any? candidates [
      set candidates patches with [ status = zone and not any? clinics-here ]
    ]

    if any? candidates [
      create-clinics 1 [
        move-to one-of candidates
        set shape "house"
        set color red
        set size 4
        set remaining-capacity global-capacity
      ]
    ]
  ]
end

to place-mobile-clinics 
  create-mobile-clinics mobile-amount [
    set shape "truck"
    set color blue
    set size 4
    set remaining-capacity mobile-capacity
    move-to-neediest-location
  ]
end

; relocates mobile clinics after relocation-threshold ticks
to update-mobile-clinics
  ask mobile-clinics [
    set time-at-location time-at-location + 1
    if time-at-location >= relocation-threshold [
      move-to-neediest-location
      set time-at-location 0
    ]
  ]
end

; moves mobile clinic to the poor patch with the lowest mean patient health
to move-to-neediest-location
  let poor-patches patches with [
  status = "poor" and
  any? patients in-radius 10 and
  not any? other mobile-clinics in-radius 10 ; avoids clustering with other mobile clinics
  ]
  let sample-patches n-of (min list 20 count poor-patches) poor-patches
  let target min-one-of sample-patches [
    mean [health] of patients in-radius 10
  ]
  if target != nobody [ move-to target ]
end

; patient count per zone is proportional to zone area
to creating-patients
  let wealthy-patches patches with [ status = "wealthy" ]
  let poor-patches patches with [ status = "poor" ]
  let wealthy-fraction (count wealthy-patches / count patches)

  let wealthy-agents-count round (total-patients * wealthy-fraction)
  let poor-agents-count total-patients - wealthy-agents-count
  
  ; Creates wealthy agents and moves them into the wealthy zone
  create-patients wealthy-agents-count
  [
    set shape "person"
    set size 1.5
    ; wealth ranges overlap slightly by design (see Section 3.2.2)
    set wealth 60 + random 40
    set health 70 + random 30 
    move-to one-of wealthy-patches
    calculate-lifespace
    set color scale-color red health 0 100
  ]
  
  ; Creates poor agents and moves them into the poor zone
  create-patients poor-agents-count
  [
    set shape "person"
    set size 1.5
    set wealth 30 + random 40
    set health 70 + random 30
    move-to one-of poor-patches
    calculate-lifespace
    set color scale-color red health 0 100
  ]
end

; health decays 1-3 points per tick; death triggers respawn in place
to update-health
  ; Natural health decay each tick
  set health health - (random 2 + 1)
  
  if health <= 1 [ respawn ] 
 
  ; Update the motility and the visual indicator based on new health
  calculate-lifespace
  set color scale-color red health 0 100
end

; resets agent in place with new health and wealth; position stays the same
to respawn
  let my-zone [status] of patch-here

  ifelse my-zone = "poor"
    [ set poor-deaths poor-deaths + 1
      set total-poor-deaths total-poor-deaths + 1
      set wealth 30 + random 40 
    ]
    [ set wealthy-deaths wealthy-deaths + 1
      set total-wealthy-deaths total-wealthy-deaths + 1
      set wealth 60 + random 40 
    ]
  
  set health 70 + random 30
  calculate-lifespace
  set color scale-color red health 0 100
end

; Patient joins the shortest queue within life-space radius
; if no clinic is reachable, recorded as no-access
to choose-clinic
  let clinics-within-range (turtle-set clinics in-radius life-space mobile-clinics in-radius life-space)
  ifelse any? clinics-within-range [
    let chosen min-one-of clinics-within-range [ count waiting-list ]
    ask chosen [ set waiting-list (turtle-set waiting-list myself) ]
  ][
    ifelse [status] of patch-here = "wealthy"
    [ set wealthy-no-access wealthy-no-access + 1
      set total-wealthy-no-access total-wealthy-no-access + 1 ]
    [ set poor-no-access poor-no-access + 1
      set total-poor-no-access total-poor-no-access + 1 ]
  ]
end

; treats the sickest patients first up to capacity; remaining patients are recorded as fail
to clinic-order
  let queue waiting-list
  while [ remaining-capacity > 0 and any? queue ] [
    let sickest-patient min-one-of queue [health]
    ask sickest-patient [
      set health health + 30
      if health > 100 [ set health 100 ]
      set color scale-color red health 0 100    
      if show-links? [
      create-link-with myself [ set color yellow set thickness 0.1 ]
      ]
    ]
    
    set remaining-capacity remaining-capacity - 1
    set queue queue with [ self != sickest-patient ]
  ]
  ; Draw red links for patients turned away due to capacity limits
  ask queue
  [
    if show-links?[
    create-link-with myself [set color red set thickness 0.1 ]
    ]
    ifelse [status] of patch-here = "wealthy"
    [ set wealthy-fail wealthy-fail + 1 
      set total-wealthy-fail total-wealthy-fail + 1]
    [ set poor-fail poor-fail + 1 
      set total-poor-fail total-poor-fail + 1]
  ]
end

; life-space radius is a function of wealth and health (spiral) or wealth only (baseline)
; see section 3.2.3 for formula derivation
to calculate-lifespace
  let base-radius 5

  let norm-wealth (wealth - 30) / 69
  let health-sigmoid (1 / (1 + exp (-0.15 * (health - health-tipping-point))))

  ifelse dynamic-lifespace?
  [ set life-space base-radius + (max-wealth-bonus * norm-wealth) + (max-health-bonus * health-sigmoid) ]
  [ set life-space base-radius + (max-wealth-bonus * norm-wealth) + (max-health-bonus * 1.0) ]

  if life-space < base-radius [ set life-space base-radius ]
end

; apply-scenario is called before random-seed so parameter values survive clear-all
to apply-scenario
  ; set default values for all scenarios first 
  set total-patients 800
  set total-clinics 10
  set global-capacity 5
  set care-threshold 60
  set max-health-bonus 15
  set max-wealth-bonus 15
  set health-tipping-point 40
  set mobile-capacity 3
  set mobile-amount 2
  set relocation-threshold 50

  ; overwrite specific values based on selection 
  if scenario = "1. Baseline (static life-space)" [
    set dynamic-lifespace? false
    set mobile-clinic-intervention? false
  ]
  if scenario = "2. Spiral of decline (dynamic life-space)" [
    set dynamic-lifespace? true
    set mobile-clinic-intervention? false
  ]
  if scenario = "3. Mobile clinic intervention" [
    set dynamic-lifespace? true
    set mobile-clinic-intervention? true
  ]
end




]]></code>
  <widgets>
    <view x="240" wrappingAllowedX="true" y="18" frameRate="30.0" minPycor="-50" height="400" showTickCounter="true" patchSize="3.921" fontSize="10" wrappingAllowedY="true" width="400" tickCounterLabel="ticks" maxPycor="50" updateMode="0" maxPxcor="50" minPxcor="-50"></view>
    <plot x="660" autoPlotX="true" yMax="1.0" autoPlotY="true" yAxis="Gap (poor rate - wealthy rate)" y="18" xMin="0.0" height="202" legend="false" xMax="10.0" yMin="0.0" width="307" xAxis="Time (Ticks)" display="No-Access Gap (Cumulative)">
      <setup></setup>
      <update></update>
      <pen interval="1.0" mode="0" display="No-Access Gap" color="-2674135" legend="true">
        <setup></setup>
        <update><![CDATA[if ticks > 0 [ plot (total-poor-no-access / count patients-on patches with [status = "poor"]) - (total-wealthy-no-access / count patients-on patches with [status = "wealthy"]) ]]]></update>
      </pen>
    </plot>
    <plot x="660" autoPlotX="true" yMax="20.0" autoPlotY="true" yAxis="Gap" y="233" xMin="0.0" height="186" legend="true" xMax="10.0" yMin="10.0" width="308" xAxis="Time (Ticks)" display="Mean Life-Space by Group">
      <setup></setup>
      <update></update>
      <pen interval="1.0" mode="0" display="Poor" color="-2674135" legend="true">
        <setup></setup>
        <update>plot mean [life-space] of patients-on patches with [status = "poor"]</update>
      </pen>
      <pen interval="1.0" mode="0" display="Wealthy" color="-10899396" legend="true">
        <setup></setup>
        <update>plot mean [life-space] of patients-on patches with [status = "wealthy"]</update>
      </pen>
    </plot>
    <plot x="978" autoPlotX="true" yMax="1.0" autoPlotY="true" y="231" xMin="0.0" height="186" legend="false" xMax="10.0" yMin="0.0" width="310" xAxis="Time (Ticks)" display="Death Gap (Cumulative)">
      <setup></setup>
      <update></update>
      <pen interval="1.0" mode="0" display="Death Gap" color="-2674135" legend="true">
        <setup></setup>
        <update><![CDATA[if ticks > 0 [ plot (total-poor-deaths / count patients-on patches with [status = "poor"]) - (total-wealthy-deaths / count patients-on patches with [status = "wealthy"]) ]]]></update>
      </pen>
    </plot>
    <button x="15" y="92" height="53" disableUntilTicks="false" forever="true" kind="Observer" width="199">go</button>
    <chooser x="15" y="164" height="96" variable="scenario" current="0" width="199" display="scenario">
      <choice type="string" value="1. Baseline (static life-space)"></choice>
      <choice type="string" value="2. Spiral of decline (dynamic life-space)"></choice>
      <choice type="string" value="3. Mobile clinic intervention"></choice>
    </chooser>
    <slider x="15" step="0.1" y="281" max="0.9" width="199" display="wealthy-clinic-ratio" height="61" min="0.5" direction="Horizontal" default="0.7" variable="wealthy-clinic-ratio"></slider>
    <switch x="15" y="363" height="54" on="true" variable="show-links?" width="199" display="show-links?"></switch>
    <button x="15" y="19" height="55" disableUntilTicks="false" forever="false" kind="Observer" width="199" display="setup">setup</button>
    <monitor x="988" precision="2" y="101" height="60" fontSize="11" width="167" display="Death Gap (Cumulative)">(total-poor-deaths / count patients-on patches with [status = "poor"]) - (total-wealthy-deaths / count patients-on patches with [status = "wealthy"])</monitor>
    <monitor x="988" precision="2" y="19" height="60" fontSize="11" width="167" display="No-Access Gap (Cumulative)">(total-poor-no-access / count patients-on patches with [status = "poor"]) - (total-wealthy-no-access / count patients-on patches with [status = "wealthy"])</monitor>
  </widgets>
  <info>## WHAT IS IT?

(a general understanding of what the model is trying to show or explain)

## HOW IT WORKS

(what rules the agents use to create the overall behavior of the model)

## HOW TO USE IT

(how to use the model, including a description of each of the items in the Interface tab)

## THINGS TO NOTICE

(suggested things for the user to notice while running the model)

## THINGS TO TRY

(suggested things for the user to try to do (move sliders, switches, etc.) with the model)

## EXTENDING THE MODEL

(suggested things to add or change in the Code tab to make the model more complicated, detailed, accurate, etc.)

## NETLOGO FEATURES

(interesting or unusual features of NetLogo that the model uses, particularly in the Code tab; or where workarounds were needed for missing features)

## RELATED MODELS

(models in the NetLogo Models Library and elsewhere which are of related interest)

## CREDITS AND REFERENCES

(a reference to the model's URL on the web if it has one, as well as any other necessary credits, citations, and links)
</info>
